# Copy to .env and fill in values.

# --- Required for production (Vercel) ---
#
# Postgres from any host (Supabase, Neon, Railway, …). On Vercel use the host’s
# *pooler* / serverless connection string (often port 6543, ?pgbouncer=true).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# NextAuth: generate with `openssl rand -base64 32`
AUTH_SECRET="replace-with-long-random-string"
#
# Public site URL (production: https://your-domain.vercel.app)
AUTH_URL="http://localhost:3000"

# --- File storage (Vercel) — use Blob; no Supabase Storage required ---
#
# In the Vercel dashboard: your project → Storage → Blob → create / attach store.
# Vercel sets BLOB_READ_WRITE_TOKEN automatically. Images, CV, and project media
# are stored as public HTTPS URLs in the database.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Optional: legacy Supabase Storage (skip if you use Blob only) ---
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY + URL/ref below are only for the old “signed URL”
# upload path. Not required when BLOB_READ_WRITE_TOKEN is set.
#
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# SUPABASE_STORAGE_BUCKET="portfolio"

# --- Admin login ---
ADMIN_PASSWORD="change-me"
# Optional production: bcrypt hash instead of plain password
# ADMIN_PASSWORD_HASH="$2a$10$..."

# --- Local dev database tip ---
# If DATABASE_URL uses a pooler and `next dev` cannot connect, use a *direct*
# Postgres URL for local work (see your provider’s dashboard).

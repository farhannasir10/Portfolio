# Copy to .env and fill in values.

# --- Database (pick ONE style; password must match Database → reset if unsure) ---
#
# LOCAL DEV (recommended): "Direct connection" in Supabase → Settings → Database.
# Host looks like db.<PROJECT_REF>.supabase.co on port 5432 (NOT aws-*.pooler...).
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.senyzxrxzdoambrsnzdd.supabase.co:5432/postgres?sslmode=require"
#
# If you see "Can't reach database server" with a pooler host (aws-*.pooler.supabase.com),
# switch to the Direct connection URI above for `next dev` on your PC.
#
# SERVERLESS (e.g. Vercel): use Supabase "Transaction pooler" URI, usually port 6543 and
# ?pgbouncer=true (copy from the dashboard; user may be postgres.<PROJECT_REF>).
#
# If the password has @, #, etc., URL-encode it (e.g. @ → %40).

# Supabase Storage — Settings → API: Project URL, anon (public) key, and service_role (server only).
# Storage → New bucket → same name as below → enable "Public bucket" so getPublicUrl works for images/PDFs/video.
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY is required for admin uploads on Vercel: the browser uploads directly to Storage
# (signed URL) so the file never goes through the serverless body-size limit or read-only disk.
#
# Project URL: set ONE of these (ref-only avoids values that look like URLs in some UIs):
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Optional server-only URL or ref (same rules as above). Browser uploads still need NEXT_PUBLIC_*.
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="portfolio"

# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Login password for /admin (use a strong password in production)
ADMIN_PASSWORD="change-me"

# Optional: bcrypt hash instead of plain ADMIN_PASSWORD (recommended for production)
# ADMIN_PASSWORD_HASH="$2a$10$..."
